}

.school-input,
.major-input,
.city-input {
  width: 100%;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: #fffdf8;
  color: #171717;
  font-size: 26rpx;
}

.school-input {
  margin-top: 28rpx;
}

.major-input {
  margin-top: 14rpx;
  background: #f1eadf;
}

.city-input {
  margin-top: 14rpx;
  background: #edf8ef;
}

.city-hint {
  display: block;
  margin-top: 10rpx;
  color: #756249;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.45;
}

.city-evidence-action-panel {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 16rpx;
  border: 1rpx solid #c9dfd1;
  border-radius: 16rpx;
  background: #f6fff8;
}

