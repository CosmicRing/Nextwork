  background: #dff2e7;
  color: #14633a;
  font-size: 20rpx;
  font-weight: 900;
}

.city-evidence-action-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 14rpx;
  border: 1rpx solid #dbeadd;
  border-radius: 14rpx;
  background: #fffdf8;
}

.city-evidence-action-title-row > text:first-child {
  min-width: 0;
  color: #191919;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.35;
}

.city-evidence-action-query {
  color: #4b4133;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.45;
}

.city-evidence-action-actions {
  justify-content: flex-end;
}

