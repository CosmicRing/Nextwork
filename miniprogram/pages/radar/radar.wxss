.radar-hero {
  margin-top: 0;
  background: #21201d;
  color: #fffdf8;
}

.radar-hero .eyebrow,
.radar-hero .muted {
  color: #d9cfbd;
}

.role-input {
  width: 100%;
  height: 76rpx;
  margin-top: 28rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: #fffdf8;
  color: #171717;
  font-size: 26rpx;
}

.role-tabs {
  width: 100%;
  margin-top: 22rpx;
  white-space: nowrap;
}

.role-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 180rpx;
  height: 64rpx;
  margin-right: 12rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d9cfbd;
  border-radius: 999rpx;
  background: #fffdf8;
  font-size: 24rpx;
  font-weight: 800;
}

.role-tab.active {
  border-color: #191919;
  background: #191919;
  color: #ffffff;
}

.radar-topline {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.role-title {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.radar-salary {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: #efe4cf;
  color: #9c2f1b;
  font-size: 24rpx;
  font-weight: 900;
}

.radar-ring-legend {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  margin-top: 18rpx;
}

.radar-ring-legend text {
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: #f5f3ed;
  color: #6f6a5d;
  font-size: 20rpx;
  font-weight: 800;
}

.radar-report-button {
  height: 50rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #191919;
  color: #fffdf8;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 50rpx;
}

.radar-chart {
  position: relative;
  width: 620rpx;
  height: 620rpx;
  max-width: 100%;
  margin: 28rpx auto 10rpx;
}

.radar-ring,
.radar-center,
.major-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.radar-ring {
  border: 2rpx solid #ded7c8;
  border-radius: 999rpx;
}

.ring-a {
  width: 560rpx;
  height: 560rpx;
}

.ring-b {
  width: 400rpx;
  height: 400rpx;
}

.ring-c {
  width: 240rpx;
  height: 240rpx;
}

.radar-center {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 156rpx;
  height: 156rpx;
  padding: 14rpx;
  border-radius: 999rpx;
  background: #191919;
  color: #fffdf8;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
}

.major-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 150rpx;
  min-height: 58rpx;
  padding: 8rpx 12rpx;
  border: 1rpx solid #cfc5b4;
  border-radius: 999rpx;
  background: #fffdf8;
  color: #171717;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
  text-align: center;
}

.major-dot.ring-1.slot-0 {
  margin-left: -92rpx;
  margin-top: -86rpx;
}

.major-dot.ring-1.slot-1 {
  margin-left: 96rpx;
  margin-top: 50rpx;
}

.major-dot.ring-2.slot-1 {
  margin-left: 155rpx;
  margin-top: -118rpx;
}

.major-dot.ring-2.slot-2 {
  margin-left: -180rpx;
  margin-top: 128rpx;
}

.major-dot.ring-3.slot-2 {
  margin-left: 220rpx;
  margin-top: 126rpx;
}

.major-dot.ring-3.slot-3 {
  margin-left: -232rpx;
  margin-top: -170rpx;
}

.major-dot.ring-4.slot-3 {
  margin-left: 238rpx;
  margin-top: -218rpx;
}

.major-dot.ring-4.slot-4 {
  margin-left: -248rpx;
  margin-top: 228rpx;
}

.major-dot.ring-5.slot-4 {
  margin-left: 0;
  margin-top: 278rpx;
}

.rank-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 26rpx;
}

.rank-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.rank-info {
  flex: 1;
  min-width: 0;
}

.rank-name {
  display: block;
  font-size: 27rpx;
  font-weight: 900;
}

.bar-track {
  width: 180rpx;
  flex: 0 0 180rpx;
  height: 18rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #ebe3d5;
}

.bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #191919;
}

.radar-report-note {
  display: block;
  margin-top: 20rpx;
  color: #817767;
  font-size: 21rpx;
  line-height: 1.5;
}

.section-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-heading text:first-child {
  font-size: 30rpx;
  font-weight: 900;
}

.section-heading text:last-child {
  color: #817767;
  font-size: 22rpx;
}

.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}
