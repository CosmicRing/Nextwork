page {
  min-height: 100%;
  background: #f7f5ef;
  color: #171717;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
  font: inherit;
  line-height: inherit;
}

button::after {
  display: none;
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx 28rpx 44rpx;
}

.section {
  margin-top: 24rpx;
  padding: 28rpx;
  border: 1rpx solid #ded7c8;
  border-radius: 18rpx;
  background: #fffdf8;
}

.eyebrow {
  display: block;
  color: #766a55;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.title {
  display: block;
  margin-top: 8rpx;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.16;
}

.muted {
  color: #6f6a5d;
  font-size: 24rpx;
  line-height: 1.55;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border: 1rpx solid #d9cfbd;
  border-radius: 999rpx;
  background: #f6f0e4;
  color: #4e4638;
  font-size: 22rpx;
  font-weight: 700;
}

.metric-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.metric-card {
  min-width: 0;
  flex: 1 1 260rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f5f3ed;
}

.metric-value {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
}

.metric-label {
  display: block;
  margin-top: 6rpx;
  color: #6f6a5d;
  font-size: 22rpx;
}

.safe-button {
  min-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #191919;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 64rpx;
  text-align: center;
}

.ghost-button {
  min-height: 58rpx;
  padding: 0 18rpx;
  border: 1rpx solid #d8cfbf;
  border-radius: 14rpx;
  background: #fffdf8;
  color: #2b2924;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 58rpx;
  text-align: center;
}

.logo-box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  flex: 0 0 72rpx;
  border: 1rpx solid #e4ddcf;
  border-radius: 16rpx;
  background: #ffffff;
}

.logo-box image {
  width: 54rpx;
  height: 54rpx;
}

.two-line {
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
